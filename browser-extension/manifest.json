{
  "manifest_version": 3,
  "name": "Microsoft Rewards Cookie Exporter",
  "version": "1.0.1",
  "description": "在本地读取 rewards.bing.com 所需 Cookie，并复制为青龙配置；不会上传任何数据。",
  "permissions": [
    "cookies",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://bing.com/*",
    "https://*.bing.com/*"
  ],
  "action": {
    "default_title": "导出 Microsoft Rewards Cookie",
    "default_popup": "popup.html"
  }
}
